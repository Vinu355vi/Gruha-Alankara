# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so

# Packaging artifacts
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
venv/
.venv/
env/
ENV/

# Flask app secrets and local database files
.flaskenv
.env
.env.*
instance/*.db
instance/*.sqlite
instance/*.sqlite3

# Test, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Logs and runtime artifacts
*.log
uploads/generated/
uploads/room_images/

# Vercel local/project metadata
.vercel/
.vercelignore

# JavaScript package artifacts (if used for frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
.vercel
.env*.local
